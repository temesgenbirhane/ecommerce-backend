  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "stop:3000": "powershell -NoProfile -Command \"$conn = Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue; if ($conn) { $conn | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force } }\"",
    "start:clean": "npm run stop:3000 && node server.js",
    "dev:clean": "npm run stop:3000 && nodemon server.js"
  },
